---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
---
<Base
  title="Contact Hume City Cleaners — Get a Free Cleaning Quote"
  description="Request a free cleaning quote from Hume City Cleaners. Call 0406 920 717 or fill in our contact form. Serving Craigieburn, Broadmeadows, Sunbury & surrounds."
>
  <section class="bg-gradient-to-br from-primary via-primary-light to-primary text-white py-14 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-5xl font-extrabold mb-4">Get in Touch</h1>
      <p class="text-lg text-gray-200">Free quotes within the hour. No obligation, no hassle.</p>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-primary mb-6">Request a Free Quote</h2>
          <ContactForm />
        </div>
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-primary mb-6">Contact Details</h2>
            <div class="space-y-4">
              <a href="tel:0406920717" class="flex items-center gap-3 p-4 bg-surface rounded-lg border border-gray-200 hover:border-accent transition-colors group">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <div>
                  <p class="text-sm text-gray-500">Phone</p>
                  <p class="font-semibold text-primary group-hover:text-accent transition-colors">0406 920 717</p>
                </div>
              </a>
              <div class="flex items-center gap-3 p-4 bg-surface rounded-lg border border-gray-200">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="text-sm text-gray-500">Hours</p>
                  <p class="font-semibold text-primary">Mon–Sat: 7am – 6pm</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-4 bg-surface rounded-lg border border-gray-200">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <p class="text-sm text-gray-500">Service Area</p>
                  <p class="font-semibold text-primary">Hume City & Northern Melbourne</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-accent/10 rounded-xl p-6 border border-accent/20">
            <h3 class="font-bold text-primary mb-2">Prefer to talk?</h3>
            <p class="text-gray-600 text-sm mb-4">Give us a call and we'll discuss your cleaning needs and provide a quote over the phone.</p>
            <a href="tel:0406920717" class="inline-block bg-accent hover:bg-accent-light text-primary-dark font-bold px-6 py-3 rounded-lg transition-colors">
              Call 0406 920 717
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
