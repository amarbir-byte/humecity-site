---
import Base from '../layouts/Base.astro';
---
<Base
  title="Thank You — Hume City Cleaners"
  description="Thanks for contacting Hume City Cleaners. We'll be in touch shortly with your free quote."
>
  <section class="py-20 sm:py-32">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div class="text-5xl mb-6">✅</div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-primary mb-4">Thank You!</h1>
      <p class="text-lg text-gray-600 mb-8">
        We've received your enquiry and will get back to you within the hour during business hours (Mon–Sat, 7am–6pm).
      </p>
      <p class="text-gray-500 mb-10">
        Need an urgent response? Give us a call directly.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0406920717" class="bg-accent hover:bg-accent-light text-primary-dark font-bold px-8 py-3.5 rounded-lg text-lg transition-colors">
          Call 0406 920 717
        </a>
        <a href="/" class="border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold px-8 py-3.5 rounded-lg text-lg transition-colors">
          Back to Home
        </a>
      </div>
    </div>
  </section>
</Base>
