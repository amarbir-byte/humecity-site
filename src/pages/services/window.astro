---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
  title="Window Cleaning in Hume City — Home & Commercial Window Cleaning"
  description="Professional window cleaning in Craigieburn, Broadmeadows & Hume City. Streak-free results inside and out. Homes, offices & shopfronts. Free quotes."
  heading="Window Cleaning"
  intro="Let the light in with crystal-clear, streak-free windows. We clean windows inside and out for homes, offices, and shopfronts across Hume City."
  serviceSlug="window"
  features={[
    'Interior and exterior window cleaning',
    'Streak-free finish using professional squeegees and solutions',
    'Window frame and track cleaning',
    'Fly screen cleaning and dusting',
    'Glass door and sliding door cleaning',
    'Shopfront and commercial glass cleaning',
    'Hard water stain removal',
    'Second-storey windows handled safely',
  ]}
  faq={[
    { q: 'Do you clean second-storey windows?', a: 'Yes, we have the equipment to safely clean windows on double-storey homes and commercial buildings.' },
    { q: 'How often should I get my windows cleaned?', a: 'For most homes, every 3–6 months keeps windows looking great. Commercial properties and shopfronts benefit from monthly cleans.' },
    { q: 'Do you clean window tracks and screens?', a: 'Yes, window tracks and fly screens are included in our standard window cleaning service.' },
  ]}
>
  <div>
    <h2 class="text-2xl font-bold text-primary mb-4">Streak-Free Guarantee</h2>
    <p class="text-gray-700 leading-relaxed">
      We use professional-grade equipment and purified water techniques to ensure a perfect, streak-free finish every time. If you spot a streak, we'll come back and fix it.
    </p>
  </div>
</ServicePage>
