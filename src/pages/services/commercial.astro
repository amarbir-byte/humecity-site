---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
  title="Commercial Cleaning in Hume City — Office & Business Cleaning"
  description="Professional commercial cleaning for offices, retail, and warehouses in Hume City. Reliable, insured cleaners. Daily, weekly, or custom schedules. Free quotes."
  heading="Commercial Cleaning"
  intro="A clean workspace keeps your team productive and your clients impressed. We provide reliable commercial cleaning for offices, shops, warehouses, and more across Hume City."
  serviceSlug="commercial"
  features={[
    'Office cleaning — desks, kitchens, meeting rooms, and common areas',
    'Retail and showroom floor cleaning and dusting',
    'Warehouse and industrial sweeping and mopping',
    'Bathroom and amenity block sanitisation',
    'Rubbish removal and bin management',
    'Window and glass partition cleaning',
    'Kitchen and breakroom deep cleaning',
    'Custom schedules — daily, weekly, or after-hours',
  ]}
  faq={[
    { q: 'Do you clean outside business hours?', a: 'Yes, we offer early morning, evening, and weekend cleaning to minimise disruption to your operations.' },
    { q: 'Can you handle large commercial spaces?', a: 'Absolutely. We clean everything from small offices to large warehouses. We\'ll scale our team to match the job.' },
    { q: 'Do you offer contract or ongoing arrangements?', a: 'Yes. We offer flexible contracts with no lock-in periods. Most commercial clients prefer weekly or bi-weekly schedules.' },
  ]}
>
  <div>
    <h2 class="text-2xl font-bold text-primary mb-4">Tailored to Your Business</h2>
    <p class="text-gray-700 leading-relaxed">
      Every business is different. We'll visit your premises, understand your needs, and create a custom cleaning plan that fits your operations and budget. From a small Broadmeadows office to a large Campbellfield warehouse, we've got you covered.
    </p>
  </div>
</ServicePage>
