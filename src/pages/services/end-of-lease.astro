---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
  title="End of Lease Cleaning in Hume City — Bond Back Guarantee"
  description="End of lease cleaning in Craigieburn, Broadmeadows & Hume City with bond-back guarantee. Professional vacate cleaning for tenants and property managers. Free quotes."
  heading="End of Lease Cleaning"
  intro="Moving out? Our thorough end of lease clean meets real estate standards and comes with a bond-back guarantee. We'll make sure you get your deposit back."
  serviceSlug="end-of-lease"
  image="/images/end-of-lease-cleaning.jpg"
  features={[
    'Full kitchen clean — oven, rangehood, stovetop, cupboards inside and out',
    'Bathroom deep clean — shower, tiles, grout, toilet, vanity, mirrors',
    'All rooms vacuumed and mopped including wardrobes and cupboards',
    'Window tracks, sills, and glass cleaned inside',
    'Light switches, power points, and door handles wiped',
    'Skirting boards, architraves, and cornices dusted',
    'Laundry — tub, cupboards, and washing machine area',
    'Garage sweep (if applicable)',
    'Wall spot cleaning and cobweb removal',
  ]}
  faq={[
    { q: 'What does your bond-back guarantee cover?', a: 'If your agent or landlord identifies cleaning issues within 72 hours, we\'ll return and fix them at no extra cost. We clean to real estate inspection standards.' },
    { q: 'How far in advance should I book?', a: 'We recommend 5–7 days notice for end of lease cleans, especially at the end of the month. We\'ll do our best to fit short-notice bookings.' },
    { q: 'Do you clean ovens and rangehoods?', a: 'Yes — oven, rangehood, and stovetop are all included in our standard end of lease package.' },
  ]}
>
  <div>
    <h2 class="text-2xl font-bold text-primary mb-4">Bond-Back Guarantee</h2>
    <p class="text-gray-700 leading-relaxed">
      We know how stressful moving can be. Our end of lease clean is designed to meet the standards set by real estate agents and property managers in the Hume City area. If there's an issue with the clean, we come back and fix it — free of charge.
    </p>
  </div>
</ServicePage>
