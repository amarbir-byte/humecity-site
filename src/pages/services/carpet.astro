---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
  title="Carpet Cleaning in Hume City — Steam & Deep Carpet Cleaning"
  description="Professional carpet steam cleaning in Craigieburn, Broadmeadows & Hume City. Remove stains, allergens & odours. Homes and offices. Free quotes. Call 0406 920 717."
  heading="Carpet Cleaning"
  intro="Revive your carpets with our professional steam cleaning service. We remove deep-set stains, dust mites, allergens, and odours — leaving your carpets fresh and like new."
  serviceSlug="carpet"
  image="/images/carpet-cleaning.jpg"
  features={[
    'Hot water extraction (steam) cleaning for deep-set dirt',
    'Pre-treatment of high-traffic areas and stains',
    'Pet stain and odour removal',
    'Allergen and dust mite reduction',
    'Fast drying times — typically 2–4 hours',
    'Safe for all carpet types including wool and synthetic',
    'Rug cleaning — pickup and delivery available',
    'End of lease carpet cleaning to real estate standards',
  ]}
  faq={[
    { q: 'How long does carpet cleaning take?', a: 'A standard 3-bedroom home takes about 1–2 hours. Drying time is typically 2–4 hours depending on ventilation.' },
    { q: 'Can you remove pet stains and odours?', a: 'Yes, we use enzyme-based treatments specifically designed for pet stains and odours. Most stains can be fully removed.' },
    { q: 'Is steam cleaning safe for my carpets?', a: 'Absolutely. Hot water extraction is recommended by most carpet manufacturers and is safe for wool, nylon, and synthetic carpets.' },
  ]}
>
  <div>
    <h2 class="text-2xl font-bold text-primary mb-4">Professional Equipment</h2>
    <p class="text-gray-700 leading-relaxed">
      We use commercial-grade hot water extraction machines that clean deeper than rental machines ever could. Combined with professional-grade cleaning solutions, we restore carpets that look beyond saving.
    </p>
  </div>
</ServicePage>
