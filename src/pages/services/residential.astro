---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
  title="Residential Cleaning in Hume City — House Cleaning Services"
  description="Professional house cleaning in Craigieburn, Broadmeadows, Sunbury & Hume City. Weekly, fortnightly or one-off cleans. Trusted, insured cleaners. Free quotes."
  heading="Residential Cleaning"
  intro="Keep your home spotless without lifting a finger. Our reliable cleaners handle everything from kitchens to bedrooms, tailored to your schedule and preferences."
  serviceSlug="residential"
  image="/images/residential-cleaning.jpg"
  features={[
    'Kitchen deep clean — benchtops, stovetop, oven exterior, sink, splashback',
    'Bathroom sanitisation — shower, bath, toilet, vanity, mirrors, tiles',
    'Bedroom and living area dusting, vacuuming, and mopping',
    'Surface wiping and cobweb removal throughout',
    'Laundry clean including washing machine exterior and tub/sink',
    'Window sill and skirting board wipe-down',
    'Rubbish removal and bin tidy',
    'Custom add-ons: oven interior, fridge interior, ironing',
  ]}
  faq={[
    { q: 'How long does a residential clean take?', a: 'A standard 3-bedroom home takes 2–3 hours. Larger homes or deep cleans may take longer. We\'ll give you an accurate time estimate with your quote.' },
    { q: 'Do I need to provide cleaning products?', a: 'No — we bring all products and equipment. If you prefer specific products or eco-friendly options, just let us know.' },
    { q: 'Can I get a regular weekly or fortnightly clean?', a: 'Absolutely. We offer recurring cleans at discounted rates. Most clients choose weekly or fortnightly schedules.' },
  ]}
>
  <div>
    <h2 class="text-2xl font-bold text-primary mb-4">Flexible Scheduling</h2>
    <p class="text-gray-700 leading-relaxed">
      Whether you need a weekly tidy, a fortnightly deep clean, or a one-off spring clean, we'll work around your schedule. Morning, afternoon, or evening — whatever suits your household. We also offer lock-up cleans if you prefer not to be home.
    </p>
  </div>
</ServicePage>
