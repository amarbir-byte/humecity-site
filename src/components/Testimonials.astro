<section class="py-14 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <h2 class="text-2xl sm:text-3xl font-bold text-center text-primary mb-10">What Our Clients Say</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { text: "Best end of lease clean we've ever had. Got our full bond back without any issues. Highly recommend!", name: "Sarah M.", area: "Craigieburn" },
        { text: "We use Hume City Cleaners for our office every week. Always professional, always thorough. Couldn't be happier.", name: "David R.", area: "Broadmeadows" },
        { text: "Called them for a last-minute carpet clean before our house inspection. They came same day and did an incredible job.", name: "Priya K.", area: "Sunbury" },
      ].map((t) => (
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="flex gap-1 text-accent mb-3">
            {[...Array(5)].map(() => <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>)}
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">"{t.text}"</p>
          <p class="font-semibold text-primary text-sm">{t.name} <span class="font-normal text-gray-400">- {t.area}</span></p>
        </div>
      ))}
    </div>
  </div>
</section>
