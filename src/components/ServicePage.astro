---
import Base from '../layouts/Base.astro';
import ContactForm from './ContactForm.astro';
import CTA from './CTA.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  intro: string;
  features: string[];
  areas?: string[];
  serviceSlug: string;
  image?: string;
  faq?: { q: string; a: string }[];
}

const { title, description, heading, intro, features, areas = ['Craigieburn', 'Broadmeadows', 'Sunbury', 'Roxburgh Park', 'Gladstone Park', 'Meadow Heights', 'Tullamarine', 'Campbellfield', 'Coolaroo', 'Dallas'], serviceSlug, image, faq = [] } = Astro.props;
---
<Base title={title} description={description}>
  <section class="relative bg-gradient-to-br from-primary via-primary-light to-primary text-white py-14 sm:py-20 overflow-hidden">
    {image && (
      <div class="absolute inset-0">
        <img src={image} alt="" class="w-full h-full object-cover opacity-20" loading="eager" />
      </div>
    )}
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-5xl font-extrabold mb-4">{heading}</h1>
      <p class="text-lg text-gray-200 max-w-2xl mx-auto">{intro}</p>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-primary mb-6">What's Included</h2>
            <ul class="space-y-3">
              {features.map(f => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-gray-700">{f}</span>
                </li>
              ))}
            </ul>
          </div>

          <slot />

          <div>
            <h2 class="text-2xl font-bold text-primary mb-4">Areas We Service</h2>
            <div class="flex flex-wrap gap-2">
              {areas.map(a => (
                <span class="bg-surface px-3 py-1.5 rounded-full text-sm text-gray-700 border border-gray-200">{a}</span>
              ))}
            </div>
          </div>

          {faq.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
              <div class="space-y-4">
                {faq.map(({ q, a }) => (
                  <details class="group bg-surface rounded-lg border border-gray-200">
                    <summary class="px-5 py-4 cursor-pointer font-medium text-primary flex items-center justify-between">
                      {q}
                      <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="px-5 pb-4 text-gray-600 text-sm leading-relaxed">{a}</div>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>

        <div class="lg:col-span-2">
          <div class="bg-surface rounded-xl p-6 border border-gray-200 sticky top-24">
            <h3 class="text-xl font-bold text-primary mb-2">Get a Free Quote</h3>
            <p class="text-gray-600 text-sm mb-6">Fill in your details and we'll get back to you within the hour.</p>
            <ContactForm service={serviceSlug} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Base>
