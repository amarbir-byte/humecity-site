---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  image?: string;
}

const { title, description, href, icon, image } = Astro.props;
---
<a href={href} class="group block bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-accent overflow-hidden">
  {image && (
    <div class="h-40 overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    </div>
  )}
  <div class="p-6">
    <div class="text-4xl mb-4">{icon}</div>
    <h3 class="text-lg font-bold text-primary group-hover:text-accent transition-colors mb-2">{title}</h3>
    <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
    <span class="inline-block mt-4 text-accent font-semibold text-sm group-hover:translate-x-1 transition-transform">
      Learn more &rarr;
    </span>
  </div>
</a>
